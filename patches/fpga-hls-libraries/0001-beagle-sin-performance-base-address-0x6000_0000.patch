From ba70264cc76112c4e51e00ece9d884e2700e6c16 Mon Sep 17 00:00:00 2001
From: Brian Burke <Brian.Burke@microchip.com>
Date: Mon, 4 Aug 2025 14:48:06 +0000
Subject: [PATCH] beagle-sin-performance-base-address-0x60000000

---
 .../riscv_tests/sin_performance/beaglev_fire/config.tcl   | 8 +-------
 1 file changed, 1 insertion(+), 7 deletions(-)

diff --git a/math/examples/riscv_tests/sin_performance/beaglev_fire/config.tcl b/math/examples/riscv_tests/sin_performance/beaglev_fire/config.tcl
index 8d7a74c..dfa2e12 100644
--- a/math/examples/riscv_tests/sin_performance/beaglev_fire/config.tcl
+++ b/math/examples/riscv_tests/sin_performance/beaglev_fire/config.tcl
@@ -5,15 +5,9 @@ set_parameter POINTSTO_ANALYZE_HW_ONLY 1
 #
 # Parameters used for SoC integration
 #
-set_parameter SOC_BD_NAME                 shls_test
 set_parameter SOC_DMA_ENGINE              HARD_DMA
-set_parameter SOC_AXI_INITIATOR           BVF_RISCV_SUBSYSTEM:FIC_0_AXI4_INITIATOR
-set_parameter SOC_AXI_TARGET              BVF_RISCV_SUBSYSTEM:FIC_0_AXI4_TARGET
-set_parameter SOC_CLOCK                   CLOCKS_AND_RESETS:FIC_0_ACLK
-set_parameter SOC_RESET                   CLOCKS_AND_RESETS:FIC_0_FABRIC_RESET_N
 set_parameter SOC_FABRIC_BASE_ADDRESS     0x60000000
-set_parameter SOC_FABRIC_SIZE             0x400000
+set_parameter SOC_FABRIC_SIZE             0x4000
 set_parameter SOC_CPU_MEM_BASE_ADDRESS    0x80000000
 set_parameter SOC_CPU_MEM_SIZE            0x60000000
-
 set_parameter CLOCK_PERIOD 5
