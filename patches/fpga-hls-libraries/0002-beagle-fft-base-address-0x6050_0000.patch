From: Brian Burke <Brian.Burke@microchip.com>
Date: Tue, 5 Aug 2025 15:30:41 +0000
Subject: [PATCH] fft-base-address-0x6050_0000

---
 dsp/examples/riscv_tests/fft_demo/beaglev_fire/config.tcl | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/dsp/examples/riscv_tests/fft_demo/beaglev_fire/config.tcl b/dsp/examples/riscv_tests/fft_demo/beaglev_fire/config.tcl
index 7134631..2b1c802 100644
--- a/dsp/examples/riscv_tests/fft_demo/beaglev_fire/config.tcl
+++ b/dsp/examples/riscv_tests/fft_demo/beaglev_fire/config.tcl
@@ -12,7 +12,7 @@ set_parameter SOC_AXI_INITIATOR           BVF_RISCV_SUBSYSTEM:FIC_0_AXI4_INITIAT
 set_parameter SOC_AXI_TARGET              BVF_RISCV_SUBSYSTEM:FIC_0_AXI4_TARGET
 set_parameter SOC_CLOCK                   CLOCKS_AND_RESETS:FIC_0_ACLK
 set_parameter SOC_RESET                   CLOCKS_AND_RESETS:FIC_0_FABRIC_RESET_N
-set_parameter SOC_FABRIC_BASE_ADDRESS     0x60000000
+set_parameter SOC_FABRIC_BASE_ADDRESS     0x60500000
 set_parameter SOC_FABRIC_SIZE             0x400000
 set_parameter SOC_CPU_MEM_BASE_ADDRESS    0x80000000
 set_parameter SOC_CPU_MEM_SIZE            0x60000000
