From b8a394f020d728c4d11e65e7b4c951790d1486e0 Mon Sep 17 00:00:00 2001
From: Lars Randers <lranders@mail.dk>
Date: Sun, 20 Apr 2025 17:11:38 +0200
Subject: [PATCH] Bring back old DESIGNVER formatting

---
 modules/misc/design_version_info.c | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/modules/misc/design_version_info.c b/modules/misc/design_version_info.c
index 7f90a293..8ac6e7a0 100644
--- a/modules/misc/design_version_info.c
+++ b/modules/misc/design_version_info.c
@@ -43,8 +43,16 @@ bool Design_Version_Info_Init(void)
         }
         mHSS_PUTC('\n');
 
+        int version = ((int)design_info_[33] << 8) + design_info_[32];
+        int year = version / 1000;
+        int month = (version / 10) % 100;
+        int patch = (version % 10);
         mHSS_FANCY_PRINTF(LOG_STATUS, "DESIGNVER: ");
-        mHSS_FANCY_PRINTF_EX("%02x%02x\n", design_info_[32], design_info_[33]);
+        mHSS_FANCY_PRINTF_EX("%02d.%02d", year, month);
+        if (patch) {
+            mHSS_FANCY_PRINTF_EX(".%d", patch);
+        }
+        mHSS_PUTC('\n');
 
         mHSS_FANCY_PRINTF(LOG_STATUS, "BACKLEVEL: ");
         mHSS_FANCY_PRINTF_EX("%02x%02x\n", design_info_[34], design_info_[35]);
-- 
2.34.1

