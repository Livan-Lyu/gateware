/dts-v1/;
/plugin/;

&{/chosen} {
	overlays {
		VERILOG-CAPE-GATEWARE = "GATEWARE_GIT_VERSION";
	};
};

/*
 * BGS variant does NOT instantiate CoreAPB3 + COREGPIO at 0x41100000/0x41200000.
 * P8/P9 pins are driven by MSS GPIO_2 directly.
 * pixel_proc is mapped through CAPE_APB_MTARGET on FIC_3 (internal APB),
 * not as a standalone peripheral at a fixed fabric address.
 *
 * If userspace UIO access to pixel_proc is needed, add a node here
 * pointing to the CAPE_APB_MTARGET base address as assigned by the MSS.
 */
